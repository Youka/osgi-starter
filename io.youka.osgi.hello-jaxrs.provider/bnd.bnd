Bundle-Version: 1.0.0.${tstamp}-SNAPSHOT
Bundle-Description: Hello jax-rs resource for http whiteboard.

-buildpath: \
    ${base-build}, \
	org.osgi.service.http.whiteboard, \
	org.apache.felix.http.servlet-api, \
	org.osgi.service.jaxrs, \
	org.apache.geronimo.specs:geronimo-jaxrs_2.1_spec, \
	org.apache.geronimo.specs:geronimo-annotation_1.3_spec

# Ignore conflict of same servlet classes in javax & jakarta packages
-contract: \
    !JavaServlet, \
    *

-testpath: \
    ${base-test}